# Cirv Accessibility Index API — environment.
# Copy to .env (gitignored) and fill in. NEVER commit real keys.

# Stripe (dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe price IDs (dashboard → Products — one recurring price per tier)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_BULK=price_xxx

# Where checkout returns the customer (your site / pricing page)
API_BASE_URL=https://api.cirvgreen.com

# Path to the scan dataset the API serves (produced by `npm run crawl`)
DATA_DB=./data/index.db

# Port
PORT=4000

# Persistent keys DB (Render: mount a disk, set KEYS_DB to a path on it so API keys survive redeploys)
KEYS_DB=/var/data/keys.db
